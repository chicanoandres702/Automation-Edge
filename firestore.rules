/**
 * Firestore Security Rules for Automaton Edge
 *
 * PHILOSOPHY:
 * This ruleset implements a strict hierarchical Ownership Model. Data access is partitioned 
 * by the user's unique identifier (UID), ensuring that users can only interact with their 
 * own profiles, automation configurations, and execution logs.
 *
 * DATA STRUCTURE:
 * - /users/{userId}: Root user profile containing preferences and Google ID.
 * - /users/{userId}/automationTasks/{taskId}: User-defined automation workflows.
 * - /users/{userId}/automationTasks/{taskId}/logEntries/{logId}: Execution history for tasks.
 *
 * KEY SECURITY DECISIONS:
 * 1. Path-Based Authorization: By nesting all data under /users/{userId}, we leverage the 
 *    Firestore path as the primary security boundary.
 * 2. Authorization Independence: Critical relational fields (like 'userId') are denormalized 
 *    into documents and validated against the path. This ensures that even if a document 
 *    is accessed via a collection group query (if enabled later), ownership is maintained 
 *    without costly cross-document lookups (get() calls).
 * 3. Prototyping Flexibility: While authorization and relational integrity are strictly 
 *    enforced, the internal schema of automation configurations and log details is left 
 *    flexible to allow for rapid iterative development.
 * 4. Immutability: Ownership links (userId) are enforced as immutable during updates to 
 *    prevent documents from being "orphaned" or transferred between users.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /** 
     * GLOBAL HELPER FUNCTIONS
     */

    /** Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks ownership and ensures the document exists for state-changing operations. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for User Profiles. Allows users to manage their own settings.
     * @path /users/{userId}
     * @allow (create) User with UID 'abc' creating /users/abc
     * @deny (create) User with UID 'abc' creating /users/xyz
     * @principle Enforces path-based ownership and validates relational ID consistency.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for Automation Tasks. Private workflows owned by the user.
       * @path /users/{userId}/automationTasks/{taskId}
       * @allow (update) User 'abc' updating their task /users/abc/automationTasks/task123
       * @deny (list) User 'abc' listing /users/xyz/automationTasks
       * @principle Authorization Independence: Validates userId in data matches the path.
       */
      match /automationTasks/{taskId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for execution logs. History entries for specific tasks.
         * @path /users/{userId}/automationTasks/{taskId}/logEntries/{logId}
         * @allow (create) User 'abc' adding a log to their task.
         * @deny (delete) User 'abc' trying to delete a log in user 'xyz's path.
         * @principle Deeply nested path-based ownership with redundant data-field validation.
         */
        match /logEntries/{logId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId;
          allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
          allow delete: if isExistingOwner(userId);
        }
      }
    }
  }
}