
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /** 
     * GLOBAL HELPER FUNCTIONS
     */

    /** Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks ownership and ensures the document exists for state-changing operations. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for User Profiles.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      match /automationTasks/{taskId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        match /logEntries/{logId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId;
          allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
          allow delete: if isExistingOwner(userId);
        }
      }
    }

    /**
     * @description Neural Lock Missions. Access permitted to any authenticated Nexus operator.
     */
    match /missions/{missionId} {
      allow get, list, write: if isSignedIn();
    }

    /**
     * @description Shared Tool Infrastructure.
     */
    match /tools/{toolId} {
      allow get, list, write: if isSignedIn();
    }
  }
}
