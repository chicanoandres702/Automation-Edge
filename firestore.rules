/**
 * Firestore Security Rules for Automaton Edge
 *
 * PHILOSOPHY:
 * This ruleset implements a strict hierarchical Ownership Model. Data access is partitioned 
 * by the user's unique identifier (UID), ensuring that users can only interact with their 
 * own profiles, automation configurations, and execution logs.
 *
 * DATA STRUCTURE:
 * - /users/{userId}: Root user profile containing preferences and Google ID.
 * - /users/{userId}/automationTasks/{taskId}: User-defined automation workflows.
 * - /users/{userId}/automationTasks/{taskId}/logEntries/{logId}: Execution history for tasks.
 * - /missions/{missionId}: Siloed mission memory (Neural Lock).
 * - /tools/{toolId}: Shared tool infrastructure hostnames.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /** 
     * GLOBAL HELPER FUNCTIONS
     */

    /** Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks ownership and ensures the document exists for state-changing operations. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for User Profiles.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      match /automationTasks/{taskId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        match /logEntries/{logId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId;
          allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
          allow delete: if isExistingOwner(userId);
        }
      }
    }

    /**
     * @description Neural Lock Missions. Access permitted to any authenticated operator.
     */
    match /missions/{missionId} {
      allow get, list, write: if isSignedIn();
    }

    /**
     * @description Shared Tool Infrastructure.
     */
    match /tools/{toolId} {
      allow get, list, write: if isSignedIn();
    }
  }
}