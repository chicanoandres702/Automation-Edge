{
  "manifest_version": 3,
  "name": "Automaton Deep Agent",
  "version": "1.0.0",
  "description": "AI Browser Automation Sidebar with Multi-Tab Deep DOM Traversal",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "tabs",
    "windows",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "Open Automaton Sidebar"
  }
}